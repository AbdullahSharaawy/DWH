                      name="Expression">#{Package\Data Flow Task\inner join between source and destination.Outputs[Lookup Match Output].Columns[Is_Active]} == 1 &amp;&amp; (#{Package\Data Flow Task\OLE DB Source.Outputs[OLE DB Source Output].Columns[Budget]} != #{Package\Data Flow Task\inner join between source and destination.Outputs[Lookup Match Output].Columns[Previous_Budget]} || #{Package\Data Flow Task\OLE DB Source.Outputs[OLE DB Source Output].Columns[Name]} != #{Package\Data Flow Task\inner join between source and destination.Outputs[Lookup Match Output].Columns[Previous_Name]})</property>
